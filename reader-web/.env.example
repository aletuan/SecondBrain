# Path to Obsidian vault (absolute or relative to reader-web/). Falls back to VAULT_ROOT, then ../vault.
READER_VAULT_ROOT=../vault

# Repo root with src/cli.ts (Brain CLI). Default: parent of reader-web/.
# READER_BRAIN_ROOT=..

# Set to 0 / false to hide POST /api/ingest (local-only safety).
# READER_ALLOW_INGEST=1

# Preview server port (serve.ts only; Vite dev uses vite.config server.port)
# READER_PORT=4173
