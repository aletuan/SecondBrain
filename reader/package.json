{
  "name": "second-brain-reader",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite build && tsx serve.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "api:dev": "cd ../api && uv run uvicorn brain_api.main:app --reload --host 127.0.0.1 --port 8765",
    "api:test": "cd ../api && uv run pytest",
    "verify-keys": "cd .. && tsx scripts/verify-keys.ts",
    "verify-apify-youtube": "cd .. && tsx scripts/verify-apify-youtube.ts",
    "verify-x-tweet": "cd .. && tsx scripts/verify-x-tweet.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "marked": "^15.0.7",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "apify-client": "^2.12.0",
    "openai": "^4.86.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^5.4.14",
    "vitest": "^3.0.8"
  }
}
