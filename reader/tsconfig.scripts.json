{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "apify-client": ["node_modules/apify-client"],
      "openai": ["node_modules/openai"],
      "yaml": ["node_modules/yaml"]
    }
  },
  "include": ["../scripts/**/*.ts"]
}
