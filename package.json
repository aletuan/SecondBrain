{
  "name": "second-brain-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api:dev": "cd api && uv run uvicorn brain_api.main:app --reload --host 127.0.0.1 --port 8765",
    "api:test": "cd api && uv run pytest",
    "reader:dev": "pnpm -C reader dev",
    "reader:build": "pnpm -C reader build",
    "reader:preview": "pnpm -C reader preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest": "tsx cli/src/cli.ts ingest",
    "translate-transcript": "tsx cli/src/cli.ts translate-transcript",
    "suggest-milestones": "tsx cli/src/cli.ts suggest-milestones",
    "verify-keys": "tsx scripts/verify-keys.ts",
    "verify-apify-youtube": "tsx scripts/verify-apify-youtube.ts",
    "verify-x-tweet": "tsx scripts/verify-x-tweet.ts",
    "strip-cau-hoi-mo": "tsx scripts/strip-cau-hoi-mo-notes.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "apify-client": "^2.12.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "jsdom": "^26.0.0",
    "openai": "^4.86.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
