# Optional overrides when `cd api` and `uv run uvicorn ŌĆ”`.
# Settings also loads the repo-root `.env` first (see `brain_api.settings`).

# Point vault at the repo `vault/` directory (not `api/vault`).
VAULT_ROOT=../vault

# YouTube / generic Apify routes (also valid in repo-root `.env`).
# APIFY_TOKEN=

# Set the same value in `reader/.env` as `INGEST_API_KEY` so the reader sends `X-Ingest-Key`.
# Leave empty on both sides to disable ingest auth (local dev).
# INGEST_API_KEY=change-me
