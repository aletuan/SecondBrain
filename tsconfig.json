{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
    "outDir": "dist",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true
  },
  "include": [
    "cli/src/**/*.ts",
    "cli/tests/**/*.ts",
    "reader/tests/**/*.ts",
    "scripts/**/*.ts",
    "vitest.config.ts"
  ]
}
