# Bản mẫu — được commit. Không điền secret vào đây.
# Lần đầu: `cp .env.example .env` rồi chỉnh **chỉ** file `.env`.

# Vault (default: ./vault relative to cwd)
VAULT_ROOT=vault

# Max bytes per downloaded capture image (optional)
# CAPTURE_IMAGE_MAX_BYTES=2000000

# Apify — https://console.apify.com/account/integrations
APIFY_TOKEN=

# OpenAI — summaries, insights, transcript translation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ingest note enrichment (Tóm tắt / Insight) — optional overrides
# ENRICH_MODEL=gpt-4o
# ENRICH_MAX_CHARS=12000   # source.md body budget; long text uses head+tail window

# YouTube transcript translation (ingest auto-translates when segments exist; standalone: translate-transcript)
# Same batch idea as youtube-crawl-translate: lines per OpenAI call (default 20)
# YT_TRANSLATE_BATCH=20
# Optional override model for translation only
# YT_TRANSLATE_MODEL=gpt-4o-mini

# Digest LLM: max chars of capture excerpts per chunk before multi-pass + merge (default 12000)
# DIGEST_LLM_MAX_CHARS=12000

# Reader web → Python ingest API (optional). Vite loads `reader/.env`, not this file.
# Copy these into reader/.env if you use `pnpm reader:dev` + `pnpm api:dev`.
# PYTHON_INGEST_URL=http://127.0.0.1:8765
# INGEST_API_KEY=   # optional shared secret; if set on Python API, set the same value in reader/.env

# X API v2 (tweet lookup, required for x.com URLs)
X_BEARER_TOKEN=

# twitter-cli (optional; full X Article body via GraphQL + cookies)
# Install: uv tool install twitter-cli
# Get cookies from browser DevTools → Application → Cookies → x.com
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
